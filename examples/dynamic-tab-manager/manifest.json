{
  "manifest_version": 3,
  "name": "Dynamic Tab Manager",
  "version": "0.6.0",
  "description": "Standalone Dynamic Tab Manager Chrome Extension built with prompt-in-a-box.",
  "prompt_in_a_box": {
    "prompt": "prompt.md",
    "alarm_minutes": 30,
    "default_provider": "anthropic",
    "default_model": "claude-sonnet-4-6"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Prompt in a Box",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "options_ui": {
    "page": "dist/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "offscreen"
  ],
  "optional_permissions": [
    "bookmarks",
    "history",
    "downloads",
    "clipboardWrite",
    "scripting",
    "contextMenus",
    "idle",
    "readingList",
    "webNavigation"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "prompt.md",
        "icon.png",
        "icon-16.png",
        "icon-32.png",
        "icon-48.png",
        "icon-128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "sandbox": {
    "pages": [
      "dist/sandbox.html"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src https://api.anthropic.com https://generativelanguage.googleapis.com https://api.openai.com;"
  }
}